# ==============================================================================
# Environment Variables Configuration
# ==============================================================================
# Copy this file to .env.local for local development
#
# For CI/CD platforms, use prefixed variable names:
#   - STAGING_VERCEL_TOKEN, STAGING_NEXT_PUBLIC_API_URL, etc.
#   - PRODUCTION_VERCEL_TOKEN, PRODUCTION_NEXT_PUBLIC_API_URL, etc.
# ==============================================================================

# ------------------------------------------------------------------------------
# Vercel Deployment
# ------------------------------------------------------------------------------
# Get these from: https://vercel.com/account/tokens
# And from .vercel/project.json after running `vercel link`
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ------------------------------------------------------------------------------
# Public Environment Variables (Client-side)
# ------------------------------------------------------------------------------
# These are bundled into the build and exposed to the browser
# Prefix with NEXT_PUBLIC_ to expose to client
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ------------------------------------------------------------------------------
# Server-side Variables (Set in Vercel Dashboard only)
# ------------------------------------------------------------------------------
# DATABASE_URL=
# API_SECRET_KEY=
# JWT_SECRET=

# ------------------------------------------------------------------------------
# Third-party Services (Examples)
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=
